# ---- Server configuration ----

# MongoDB connection string.
# Local:  mongodb://127.0.0.1:27017/task-manager
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/task-manager?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/task-manager

# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET=replace_this_with_a_long_random_secret_string

# How long a login session stays valid.
JWT_EXPIRE=7d

# Port the server listens on (Railway sets PORT automatically).
PORT=5000

# Set to "production" on Railway.
NODE_ENV=development
